# Copy this file to configs/secrets.local.yaml and fill in your own values.
# configs/secrets.local.yaml is intentionally ignored by git.

moonshotApiKey: sk-your-moonshot-key
volcengineApiKey: your-volcengine-key

# Optional: add CUDA runtime DLL directories if faster-whisper cannot find
# cublas/cudnn DLLs on Windows. You can also set JARVIS_ASR_CUDA_DLL_DIRS.
asrCudaDllDirs: []
